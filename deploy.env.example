# Copie este arquivo para deploy.env e preencha os dados reais.

# Protocolo: sftp (recomendado), ftps ou ftp
DEPLOY_PROTOCOL=sftp

# Servidor
DEPLOY_HOST=
DEPLOY_PORT=

# Credenciais
DEPLOY_USER=
DEPLOY_PASSWORD=

# Pasta remota onde os arquivos serao publicados
DEPLOY_REMOTE_DIR=

# Pasta local para publicar (padrao: pasta do script)
DEPLOY_LOCAL_DIR=

# Regex para ignorar itens no upload (separe por |)
DEPLOY_EXCLUDE=.git/|.gitignore|deploy.env|deploy.env.example|deploy.sh

# Para FTPS: false para ignorar validacao do certificado (uso temporario)
DEPLOY_VERIFY_CERT=false

# Credenciais fixas do painel de feedback
PAINEL_EMAIL=
PAINEL_SENHA_HASH=
